{
  "name": "app",
  "description": "website/nodejs/electron application",
  "author": "chris saunders",
  "version": "1.0.7",
  "private": true,
  "main": "main.js",
  "build": {
    "icon": "",
    "productName": "Electron Build",
    "directories": {
      "output": "electron-build"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "server/server.js",
      "server/**/*"
    ],
    "extraResources": [
      "public/**/*",
      ".env"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "runAfterFinish": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "electron-build"
    },
    "linux": {},
    "mac": {}
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron-serve": "cross-env NODE_ENV=development dotenv -e .env.local vite build && electron . --no-sandbox",
    "electron-build": "npm run build && .\\node_modules\\.bin\\electron-builder",
    "mac-electron-build": "electron-builder",
    "mac-electron-build-win": "electron-builder --win",
    "start": "node server.js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "archiver": "^6.0.1",
    "basic-ftp": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "electron-serve": "^1.1.0",
    "express": "^4.18.2",
    "formidable": "^3.4.0",
    "fs": "^0.0.1-security",
    "helmet": "^7.0.0",
    "http": "^0.0.1-security",
    "http-server": "^14.1.1",
    "nodemailer": "^6.9.3",
    "pdf-vue3": "^1.0.12",
    "pinia": "^2.1.3",
    "simple-keyboard": "^3.7.61",
    "vue": "^3.3.4",
    "vue-router": "^4.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.3",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "electron": "^25.1.0",
    "electron-builder": "^24.13.3",
    "sass": "^1.63.6",
    "sass-loader": "^13.3.2",
    "style-resources-loader": "^1.5.0",
    "vite": "^4.3.9"
  }
}